# Database
POSTGRES_DB=paynext_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# JWT
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRATION_SECONDS=86400

# Frontend URL (used for CORS and invite links)
FRONTEND_BASE_URL=http://localhost:3000
FRONTEND_RESET_PASSWORD_PATH=/reset-password

# Backend API URL exposed to the browser
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# Internal URL used by the frontend container to reach the API service
API_INTERNAL_URL=http://core-monolith:8080

# SendGrid (notification service)
SENDGRID_API_KEY=SG.xxxxxx
SENDGRID_FROM_EMAIL=no-reply@yourdomain.com
SENDGRID_FROM_NAME=YourApp

# Optional port overrides
CORE_PORT=8080
FRONTEND_PORT=3000
